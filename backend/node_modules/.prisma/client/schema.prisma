generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}


model users {
  id         Int      @id @default(autoincrement()) // PRIMARY KEY
  name       String
  email      String   @unique                       // must be unique
  password   String                                 // bcrypt hashed
  role       String   @default("MEMBER")            // ADMIN or MEMBER
  created_at DateTime @default(now())

  // one user can have many issue records
  issues issues[]
}


model books {
  id               Int      @id @default(autoincrement()) // PRIMARY KEY
  book_code        String   @unique                       // e.g. BOOK001
  title            String
  author_name      String
  total_copies     Int                                    // total books
  available_copies Int                                    // how many can be lent now
  status           String   @default("Active")           // Active or Inactive
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  // one book can have many issue records
  issues issues[]
}


model issues {
  id           Int       @id @default(autoincrement()) // PRIMARY KEY
  issue_code   String    @unique                       // e.g. ISS1719000000000
  book_id      Int                                     // FOREIGN KEY → books.id
  user_id      Int                                     // FOREIGN KEY → users.id
  //issued_to    String                                  // name of member
  issue_date   DateTime                                // date book was lent
  due_date     DateTime                                // issue_date + 7 days
  return_date  DateTime?                               // null until returned
  issue_status String    @default("Issued")            // Issued or Returned
  delay_days   Int?                                    // how many days late
  delay_status String?                                 // On Time or Delayed
  penalty      Float?                                  // delay_days × 10
  is_deleted   Boolean   @default(false)               // soft delete flag
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  // relations
  book  books @relation(fields: [book_id], references: [id])
  user  users @relation(fields: [user_id], references: [id])
}
